<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE generatorConfiguration
        PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
        "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">
<generatorConfiguration>
    <properties resource="db.properties"/>
    <context id="MariaDBTables" targetRuntime="MyBatis3Kotlin">
        <commentGenerator>
            <property name="suppressData" value="true"/>
        </commentGenerator>

        <jdbcConnection
                driverClass="${db.driverClass}"
                connectionURL="${db.connectionURL}"
                userId="${db.userId}"
                password="${db.password}"/>
        <modelGenerator
                targetPackage="${project.targetPackage}.record"
                targetProject="${project.targetDir}"/>
        <clientGenerator
                targetPackage="${project.targetPackage}.mapper"
                targetProject="${project.targetDir}"/>

        <table tableName="user" catalog="book_manager">
            <property name="ignoreQualifiersAtRuntime" value="true"/>
            <columnOverride
                    column="role_type"
                    typeHandler="org.apache.ibatis.type.EnumTypeHandler"
                    javaType="jp.ac.it_college.std.s25005.kotlin.book.manager.domain.type.RoleType"/>
        </table>

        <table tableName="book" catalog="book_manager">
            <property name="ignoreQualifiersAtRuntime" value="true"/>
        </table>

        <table tableName="rental" catalog="book_manager">
            <property name="ignoreQualifiersAtRuntime" value="true"/>
        </table>
    </context>


    <context id="MariaDBViews" targetRuntime="MyBatis3Kotlin">
        <plugin type="org.mybatis.generator.plugins.dsql.ReadOnlyPlugin"/>
        <commentGenerator>
            <property name="suppressData" value="true"/>
        </commentGenerator>

        <jdbcConnection
                driverClass="${db.driverClass}"
                connectionURL="${db.connectionURL}"
                userId="${db.userId}"
                password="${db.password}"/>
        <modelGenerator
                targetPackage="${project.targetPackage}.record"
                targetProject="${project.targetDir}"/>
        <clientGenerator
                targetPackage="${project.targetPackage}.mapper"
                targetProject="${project.targetDir}"/>


        <table tableName="book_with_rental" catalog="book_manager">
            <property name="ignoreQualifiersAtRuntime" value="true"/>
        </table>

    </context>
</generatorConfiguration>